import pandas as pd
import numpy as np

df = pd.read_csv("ipo.csv")

# Clean columns
df.columns = df.columns.str.strip().str.replace(" ","_")

# Convert date
df["Date"] = pd.to_datetime(df["Date"])
df["Year"] = df["Date"].dt.year

# Remove invalid issue price
df = df[df["Issue_price"] > 0]

# Calculate listing gain %
df["Calculated_Gain_%"] = (
    (df["Listing_Open"] - df["Issue_price"]) / df["Issue_price"]
) * 100

df["Calculated_Gain_%"] = df["Calculated_Gain_%"].round(2)

# Average gain
print("Average Gain:", df["Calculated_Gain_%"].mean())

# Top IPOs
print(df.sort_values("Calculated_Gain_%", ascending=False).head(10))

# Correlation with QIB
print(df[["QIB","Calculated_Gain_%"]].corr())

# Save
df.to_csv("ipo_cleaned.csv", index=False)
